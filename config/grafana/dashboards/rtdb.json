{
  "dashboard": {
    "id": null,
    "title": "RTDB Monitoring",
    "tags": ["rtdb"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Query Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(rtdb_queries_total[5m])",
            "legendFormat": "Queries/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Query Latency (P99)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(rtdb_query_duration_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Vector Count",
        "type": "stat",
        "targets": [
          {
            "expr": "rtdb_vectors",
            "legendFormat": "Vectors"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Collection Count",
        "type": "stat",
        "targets": [
          {
            "expr": "rtdb_collections",
            "legendFormat": "Collections"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "5s"
  }
}
